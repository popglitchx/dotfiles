* {
  color-fg: #ebdbb2;
  color-bg: #282828;
  color-black: #1d2021;
  color-blue: #83a598;
  color-yellow: #fabd2f;
  color-red: #fb4934;
  color-white: #d5c4a1;
  color-green: #b8bb26;
  color-gray: #3c3836;
  color-lightgray: #665c54;
  rounded-sm: 2px;
  rounded-md: 6px;
  rounded-lg: 8px;
  rounded-xl: 12px;
  rounded-full: 9999px;
}
