#####################
###  APPEARANCE   ###
#####################

# i3-gaps features are built into modern i3 installations
gaps inner 5
#gaps outer 20

# Smart gaps (No gaps if only one window is visible)
smart_gaps on

# Border settings
#default_border pixel 2
#default_floating_border normal 2
hide_edge_borders none

# Note: i3wm doesn't natively support blur, window rounding, shadow, or animations.
# If you want shadows/blur, you will need to run an external compositor like Picom.

# Colors: active_border (cyan/green gradient fallback to flat cyan), inactive_border
# Format: class           border  backgr. text    indicator child_border
#client.focused          #33ccff #33ccff #ffffff #00ff99   #33ccff
#client.unfocused        #595959 #595959 #888888 #595959   #595959
#client.focused_inactive #595959 #595959 #888888 #595959   #595959

# color defines for zenburn styled i3
set $bg     #282828
set $fg     #ebdbb2
set $hi     #928374
set $ac     #504945
set $tx     #ebdbb2
set $ia     #504945
set $gn     #98971a
set $rd     #cc241d

# set some nice colors      border     background  text
client.focused              $ac        $ac         $tx
client.unfocused            $bg        $bg         $ia
client.focused_inactive     $bg        $bg         $ac
client.urgent               $rd        $rd         $tx

###################
### KEYBINDINGS ###
###################

# Floating window controls (Hold Mod4 + Left Mouse Button to drag, Right Mouse Button to resize)
floating_modifier $mainMod

# move tiling windows via drag & drop by left-clicking into the title bar,
# or left-clicking anywhere into the window while holding the floating modifier.
tiling_drag modifier titlebar

# --- Core Window Manager Actions ---
bindsym $mainMod+q exec "$terminal --class normal_terminal,Alacritty -e ~/.local/bin/kitty-tmux"
bindsym $mainMod+Shift+q kill
bindsym $mainMod+Shift+m exit
bindsym $mainMod+e exec $fileManager
bindsym $mainMod+d $menu
bindsym $mainMod+Shift+d $scripts

#bindsym $mainMod+d exec --no-startup-id i3-dmenu-desktop

# Toggle Floating
bindsym $mainMod+Shift+space floating toggle
bindsym $mainMod+button2 floating toggle

# change focus between tiling / floating windows
bindsym $mainMod+space focus mode_toggle

# --- Layout ---
bindsym $mainMod+Shift+j split toggle

bindsym $mainMod+f fullscreen toggle

# split in horizontal orientation
bindsym $mainMod+Shift+h split h

# split in vertical orientation
bindsym $mainMod+Shift+v split v

# i3 Layout Adjustments (Closest alternatives to your dwindle setup)
#bindsym $mainMod+r layout toggle split

# Move container to next output (monitor)
bindsym $mainMod+m move workspace to output next

# --- Focus (vim keys) ---
bindsym $mainMod+h focus left
bindsym $mainMod+j focus down
bindsym $mainMod+k focus up
bindsym $mainMod+l focus right

